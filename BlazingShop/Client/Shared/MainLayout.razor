@inherits LayoutComponentBase

<div class="relative flex flex-col h-screen">
    <div class="flex flex-1">
        <div class="hidden md:block md:w-64 bg-gradient-to-b from-blue-900 to-purple-900 sticky top-0 h-screen overflow-y-auto">
            <NavMenu />
        </div>

        <div class="flex-1 flex flex-col">
            <div class="bg-gray-100 border-b border-gray-300 px-4 h-14 flex items-center justify-end sticky top-0 z-10">
                <TopMenu />
            </div>

            <div class="flex-1 px-4 py-6 overflow-y-auto">
                @Body
            </div>
        </div>
    </div>
    <div class="md:hidden">
        <NavMenu />
    </div>
</div>
<BlazoredToasts />
